# Server
PORT=9876

# Comma-separated list of allowed CORS origins (leave blank to allow all origins)
# Example: CORS_ORIGINS=https://your-domain.com,https://other-domain.com
CORS_ORIGINS=

# Data directories (defaults used when unset)
DB_PATH=./data/db/showstack.db
MEDIA_DIR=./data/media
LOGS_DIR=./logs

# Node environment
NODE_ENV=production
